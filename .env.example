# BloodSaathi Environment Configuration
# Copy this file to .env and fill in your actual Firebase configuration values

# Firebase Configuration
# Get these values from your Firebase project settings
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id

# Application Configuration
REACT_APP_APP_NAME=BloodSaathi
REACT_APP_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_VOICE_MESSAGES=true
REACT_APP_ENABLE_REAL_TIME=true

# API Configuration
REACT_APP_API_TIMEOUT=30000
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_SUPPORTED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Emergency Configuration
REACT_APP_EMERGENCY_PHONE=+91-XXXX-XXXX-XX
REACT_APP_EMERGENCY_EMAIL=emergency@bloodsaathi.com
REACT_APP_SUPPORT_EMAIL=support@bloodsaathi.com

# Notification Configuration
REACT_APP_NOTIFICATION_TIMEOUT=10000
REACT_APP_AUDIO_ENABLED=true
REACT_APP_VIBRATION_ENABLED=true

# Localization
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_SUPPORTED_LANGUAGES=en,hi

# Development Configuration (only for development)
REACT_APP_DEBUG_MODE=false
REACT_APP_MOCK_DATA=false
REACT_APP_BYPASS_AUTH=false

# Security Configuration
REACT_APP_SESSION_TIMEOUT=3600000
REACT_APP_MAX_LOGIN_ATTEMPTS=5
REACT_APP_PASSWORD_MIN_LENGTH=8

# Performance Configuration
REACT_APP_CACHE_DURATION=300000
REACT_APP_RETRY_ATTEMPTS=3
REACT_APP_RETRY_DELAY=1000

# Analytics Configuration (optional)
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_FIREBASE_ANALYTICS_ENABLED=true

# Social Media Links (optional)
REACT_APP_FACEBOOK_URL=
REACT_APP_TWITTER_URL=
REACT_APP_INSTAGRAM_URL=
REACT_APP_LINKEDIN_URL=

# Legal Links
REACT_APP_PRIVACY_POLICY_URL=/privacy-policy
REACT_APP_TERMS_OF_SERVICE_URL=/terms-of-service
REACT_APP_CONTACT_URL=/contact

# Blood Bank Integration (future feature)
REACT_APP_BLOOD_BANK_API_URL=
REACT_APP_BLOOD_BANK_API_KEY=

# SMS Service Configuration (future feature)
REACT_APP_SMS_SERVICE_URL=
REACT_APP_SMS_SERVICE_KEY=

# Email Service Configuration (future feature)
REACT_APP_EMAIL_SERVICE_URL=
REACT_APP_EMAIL_SERVICE_KEY=

# Map Service Configuration (future feature)
REACT_APP_GOOGLE_MAPS_API_KEY=
REACT_APP_MAP_DEFAULT_ZOOM=12

# Push Notification Configuration (future feature)
REACT_APP_VAPID_PUBLIC_KEY=
REACT_APP_FCM_SERVER_KEY=

# Content Delivery Network (optional)
REACT_APP_CDN_URL=

# Error Reporting (optional)
REACT_APP_SENTRY_DSN=
REACT_APP_ERROR_REPORTING_ENABLED=false

# Rate Limiting
REACT_APP_RATE_LIMIT_REQUESTS=100
REACT_APP_RATE_LIMIT_WINDOW=3600000

# File Upload Configuration
REACT_APP_MAX_VOICE_MESSAGE_SIZE=5242880
REACT_APP_MAX_CERTIFICATE_SIZE=10485760
REACT_APP_MAX_PROFILE_IMAGE_SIZE=2097152

# Donation Configuration
REACT_APP_MIN_DONATION_INTERVAL=90
REACT_APP_MIN_DONOR_AGE=18
REACT_APP_MAX_DONOR_AGE=65
REACT_APP_MIN_DONOR_WEIGHT=50

# Request Configuration
REACT_APP_REQUEST_EXPIRY_HOURS=24
REACT_APP_MAX_UNITS_PER_REQUEST=10
REACT_APP_AUTO_CANCEL_HOURS=48

# Notification Timing
REACT_APP_IMMEDIATE_RESPONSE_MINUTES=10
REACT_APP_URGENT_RESPONSE_MINUTES=30
REACT_APP_NORMAL_RESPONSE_HOURS=2

# System Maintenance
REACT_APP_MAINTENANCE_MODE=false
REACT_APP_MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.

# Backup Configuration
REACT_APP_BACKUP_ENABLED=true
REACT_APP_BACKUP_INTERVAL=86400000

# Monitoring
REACT_APP_HEALTH_CHECK_INTERVAL=300000
REACT_APP_PERFORMANCE_MONITORING=true

# Compliance
REACT_APP_GDPR_ENABLED=true
REACT_APP_COOKIE_CONSENT=true
REACT_APP_DATA_RETENTION_DAYS=2555

# Testing Configuration (development only)
REACT_APP_TEST_MODE=false
REACT_APP_MOCK_FIREBASE=false
REACT_APP_SKIP_AUTH_VERIFICATION=false

# Build Configuration
GENERATE_SOURCEMAP=false
INLINE_RUNTIME_CHUNK=false
IMAGE_INLINE_SIZE_LIMIT=0

# PWA Configuration
REACT_APP_PWA_ENABLED=true
REACT_APP_OFFLINE_ENABLED=true
REACT_APP_CACHE_FIRST=true

# Security Headers
REACT_APP_CSP_ENABLED=true
REACT_APP_HSTS_ENABLED=true
REACT_APP_XSS_PROTECTION=true